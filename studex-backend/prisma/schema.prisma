generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  DRIVER
  ADMIN
}

enum OrderStatus {
  MENCARI_DRIVER
  DIPROSES_DRIVER
  DRIVER_DI_TOKO
  DALAM_PERJALANAN
  DRIVER_SAMPAI
  PESANAN_TIBA
  COMPLETED
  CANCELLED
}

enum CancelledBy {
  USER
  SYSTEM
}

enum ReportStatus {
  PENDING
  INVESTIGATING
  RESOLVED
  DISMISSED
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

model User {
  id                 Int            @id @default(autoincrement())
  username           String?        @unique
  name               String
  email              String         @unique
  password           String?
  googleId           String?        @unique @map("google_id")
  profilePic         String?        @map("profile_pic")
  phoneNumber        String?        @map("phone_number")
  fakultas           String?
  jurusan            String?
  universitas        String?
  role               Role           @default(USER)
  accountStatus      AccountStatus  @default(ACTIVE) @map("account_status")
  isDriverVerified   Boolean        @default(false) @map("is_driver_verified")
  createdAt          DateTime       @default(now()) @map("created_at")

  driverProfile      DriverProfile?
  ordersAsBuyer      Order[]        @relation("BuyerOrders")
  ordersAsDriver     Order[]        @relation("DriverOrders")
  ratingsGiven       Rating[]       @relation("RatingsGiven")
  ratingsReceived    Rating[]       @relation("RatingsReceived")
  reportsCreated     Report[]       @relation("ReportsCreated")
  reportsReceived    Report[]       @relation("ReportsReceived")

  @@map("users")
}

model DriverProfile {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique @map("user_id")
  ktmUrl     String   @map("ktm_url")
  qrisUrl    String   @map("qris_url")
  isActive   Boolean  @default(false) @map("is_active")
  avgRating  Decimal  @default(0.00) @map("avg_rating") @db.Decimal(3, 2)
  totalTrips Int      @default(0) @map("total_trips")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("driver_profiles")
}

model Order {
  id               Int         @id @default(autoincrement())
  userId           Int         @map("user_id")
  driverId         Int?        @map("driver_id")
  shopName         String      @map("shop_name")
  itemsDescription Json        @map("items_description")
  notes            String?
  // Pembayaran P2P face-to-face via QRIS; tidak ada kolom harga di sistem.
  status           OrderStatus @default(MENCARI_DRIVER)
  cancelledBy      CancelledBy? @map("cancelled_by")
  cancelReason     String?     @map("cancel_reason")
  buyerLat         Decimal     @map("buyer_lat") @db.Decimal(10, 7)
  buyerLng         Decimal     @map("buyer_lng") @db.Decimal(10, 7)
  deliveryAddress  String?     @map("delivery_address")
  stepTimestamps   Json?       @map("step_timestamps")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @default(now()) @map("updated_at")

  buyer            User        @relation("BuyerOrders", fields: [userId], references: [id])
  driver           User?       @relation("DriverOrders", fields: [driverId], references: [id])
  ratings          Rating[]
  reports          Report[]

  @@index([status])
  @@index([driverId])
  @@index([userId])
  @@index([updatedAt])
  @@map("orders")
}

model Report {
  id         Int          @id @default(autoincrement())
  reporterId Int          @map("reporter_id")
  reportedId Int          @map("reported_id")
  orderId    Int?         @map("order_id")
  reason     String
  details    String
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  reporter   User         @relation("ReportsCreated", fields: [reporterId], references: [id])
  reported   User         @relation("ReportsReceived", fields: [reportedId], references: [id])
  order      Order?       @relation(fields: [orderId], references: [id])

  @@index([status])
  @@map("reports")
}

model Rating {
  id        Int      @id @default(autoincrement())
  orderId   Int      @map("order_id")
  fromUser  Int      @map("from_user")
  toUser    Int      @map("to_user")
  score     Int
  createdAt DateTime @default(now()) @map("created_at")

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  giver     User     @relation("RatingsGiven", fields: [fromUser], references: [id])
  receiver  User     @relation("RatingsReceived", fields: [toUser], references: [id])

  @@unique([orderId, fromUser])
  @@map("ratings")
}
